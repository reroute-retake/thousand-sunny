# Copy to deploy/.env and fill. NEVER commit the real .env (see ../.gitignore).
# Secrets belong in Vaultwarden and/or a SOPS/age-encrypted store — this file is just the shape.

# --- Common ---
VPS_PUBLIC_IP=203.0.113.10
DOMAIN=example.com
ACME_EMAIL=admin@example.com
SSH_PORT=2222

# --- WireGuard (Path A) ---
# Generate: wg genkey | tee vps.key | wg pubkey > vps.pub   (repeat on the home side)
VPS_PRIVATE_KEY=
VPS_PUBLIC_KEY=
HOME_PRIVATE_KEY=
HOME_PUBLIC_KEY=
WG_LISTEN_PORT=51820
WG_VPS_ADDRESS=10.88.0.1/24
WG_HOME_TUNNEL_IP=10.88.0.2
HOME_SERVERS_CIDR=10.10.20.0/24

# --- Pangolin / Newt (Path B) ---
DASHBOARD_DOMAIN=dashboard.example.com
PANGOLIN_ENDPOINT=https://dashboard.example.com
NEWT_ID=
NEWT_SECRET=

# puffingtom (VPS) side — WireGuard "server". Public UDP :51820.
# Copy to /etc/wireguard/wg0.conf (chmod 600) and fill keys. Keys live in Vaultwarden/SOPS.
# The Ansible caddy role proxies public hostnames to home LAN IPs *over this tunnel*.

[Interface]
Address = 10.88.0.1/24
ListenPort = 51820
PrivateKey = <VPS_PRIVATE_KEY>          # wg genkey

[Peer]
# home (bartolomeo / OPNsense) — it dials out, so there is NO Endpoint line here.
PublicKey = <HOME_PUBLIC_KEY>
# Tunnel IP + the home Servers VLAN, so Caddy on the VPS can reach services (e.g. Jellyfin 10.10.20.11).
AllowedIPs = 10.88.0.2/32, 10.10.20.0/24

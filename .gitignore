# ── Secrets & credentials — NEVER commit ─────────────────────────
.env
.env.*
*.key
*.pem
*.crt
*.p12
secrets/
**/secrets.yml
**/*secret*
wg*.conf
*.kdbx

# ── Runtime / generated ──────────────────────────────────────────
*.log
*.tmp
*.bak
.DS_Store
Thumbs.db

# ── Compose overrides that may contain host-specific data ────────
docker-compose.override.yml
**/appdata/
**/config/*.db

# ── Editor ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── Notes: this repo is documentation.
# Real service configs live on the hosts and in a private, encrypted
# repo (SOPS/age). Only sanitized examples belong here.

# ── Deploy kit — commit only *.example / *.j2 templates, never filled values ──
deploy/**/.env
deploy/ansible/inventory.ini
deploy/ansible/group_vars/edge.yml
deploy/**/*.conf
!deploy/**/*.conf.example
deploy/pangolin/config/

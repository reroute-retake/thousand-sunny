# ct-media — copy to .env (git-ignored). See stacks/README.md for conventions.
TZ=Asia/Kolkata
PUID=1000
PGID=1000

# Paths
APPDATA=/opt/appdata            # NVMe: fast/appdata
MEDIA=/mnt/tank/media           # HDD ZFS mirror: tank/media (library + downloads on same dataset for hardlinks)

# Decypharr / AllDebrid (doc 06)
ALLDEBRID_API_KEY=REPLACE_ME

# ct-proxy — copy to .env (git-ignored). Web + identity tier (doc 05).
TZ=Asia/Kolkata
APPDATA=/opt/appdata
DOMAIN=sunny.home

# Vaultwarden admin token — generate a hash:  docker run --rm vaultwarden/server /vaultwarden hash
VAULTWARDEN_ADMIN_TOKEN=REPLACE_WITH_ARGON2_HASH

# Authelia secrets — long random strings. Store in Vaultwarden AND the break-glass copy (doc 11).
# (map these to Authelia's AUTHELIA_* env names per authelia.com/configuration/methods/secrets)
AUTHELIA_JWT_SECRET=REPLACE
AUTHELIA_SESSION_SECRET=REPLACE
AUTHELIA_STORAGE_ENCRYPTION_KEY=REPLACE

# ct-cloud (Nextcloud AIO) — copy to .env (git-ignored).
TZ=Asia/Kolkata

# AIO exposes its reverse-proxy entry on APACHE_PORT (Caddy on bartolomeo proxies to it).
APACHE_PORT=11000

# Where Nextcloud stores user data (HDD ZFS mirror). Must be an absolute path.
NEXTCLOUD_DATADIR=/mnt/tank/nextcloud

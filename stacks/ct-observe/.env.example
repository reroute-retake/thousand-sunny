# ct-observe — copy to .env (git-ignored).
TZ=Asia/Kolkata
APPDATA=/opt/appdata

GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
BESZEL_AGENT_KEY=REPLACE_WITH_BESZEL_HUB_PUBLIC_KEY   # from the Beszel hub UI when adding this system
HOMEPAGE_ALLOWED_HOSTS=home.sunny.home

# Homepage widget API keys (optional) — uncomment the matching widget: blocks in
# config/homepage/services.yaml after filling these in.
HOMEPAGE_VAR_RADARR_KEY=
HOMEPAGE_VAR_SONARR_KEY=
HOMEPAGE_VAR_PROWLARR_KEY=
HOMEPAGE_VAR_JELLYFIN_KEY=
HOMEPAGE_VAR_SABNZBD_KEY=
HOMEPAGE_VAR_PROXMOX_TOKEN=

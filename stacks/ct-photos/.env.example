# ct-photos (Immich) — copy to .env (git-ignored).
TZ=Asia/Kolkata

IMMICH_VERSION=v3.0.2
UPLOAD_LOCATION=/mnt/tank/photos          # HDD ZFS mirror: tank/photos (the library)
DB_DATA_LOCATION=/opt/appdata/immich/pgdata   # NVMe: fast/appdata (database)

# Postgres
DB_USERNAME=immich
DB_DATABASE_NAME=immich
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

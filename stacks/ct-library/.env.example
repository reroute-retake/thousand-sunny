# ct-library — copy to .env (git-ignored).
TZ=Asia/Kolkata
PUID=1000
PGID=1000

APPDATA=/opt/appdata            # NVMe: configs + DBs
DOCS=/mnt/tank/docs             # HDD: Paperless documents/consume
BOOKS=/mnt/tank/books           # HDD: Kavita library
MUSIC=/mnt/tank/music           # HDD: Navidrome library

# Paperless-ngx
PAPERLESS_DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
PAPERLESS_SECRET_KEY=REPLACE_WITH_LONG_RANDOM_STRING
PAPERLESS_URL=https://paperless.sunny.home
